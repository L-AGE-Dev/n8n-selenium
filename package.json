{
	"name": "n8n-nodes-lage-selenium",
	"version": "1.0.1",
	"description": "n8n node package for selenium",
	"license": "MIT",
	"homepage": "https://lage-beauty.de/",
	"keywords": [
		"n8n-community-node-package",
		"selenium"
	],
	"author": {
		"name": "Joel Schnubel",
		"email": "dev@lage-ecommerce.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/L-AGE-Dev/n8n-selenium.git"
	},
	"publishConfig": {
		"access": "public",
		"tag": "next"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist",
		"icons"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/SeleniumApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Selenium/Selenium.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
